{
  "translationsPath": "translations",
  "loadTranslationOverrides": false,
  "assetsPath": "assets",
  "themesUrl": "/themes.json",
  "availableLocales": {
    "en-US": "English",
    "de-CH": "Deutsch",
    "fr-FR": "Français",
    "it-IT": "Italiano"
  },
  "urlPositionFormat": "centerAndZoom",
  "urlPositionCrs": "",
  "omitUrlParameterUpdates": false,
  "preserveExtentOnThemeSwitch": true,
  "preserveBackgroundOnThemeSwitch": true,
  "preserveNonThemeLayersOnThemeSwitch": true,
  "allowReorderingLayers": true,
  "preventSplittingGroupsWhenReordering": false,
  "allowLayerTreeSeparators": false,
  "allowRemovingThemeLayers": true,
  "globallyDisableDockableDialogs": false,
  "searchThemes": true,
  "allowAddingOtherThemes": true,
  "allowFractionalZoom": false,
  "localeAwareNumbers": false,
  "identifyTool": "Identify",
  "wmsDpi": 96,
  "wmsHidpi": true,
  "qgisServerVersion": 3,
  "username": "",
  "defaultFeatureStyle": {
    "strokeColor": [0, 0, 255, 1],
    "strokeWidth": 2,
    "strokeDash": [4],
    "fillColor": [0, 0, 255, 0.33],
    "circleRadius": 10,
    "textFill": "black",
    "textStroke": "white",
    "textFont": "11pt sans-serif"
  },
  "importLayerUrlPresets": [
    {"label": "SwissTopo WMS", "value": "https://wms.geo.admin.ch/?SERVICE=WMS&REQUEST=GetCapabilities"},
    {"label": "OpenStreetMap WMS", "value": "https://ows.terrestris.de/osm/service?SERVICE=WMS&REQUEST=GetCapabilities"}
  ],
  "projections": [
    {"code": "EPSG:3857", "proj": "+proj=merc +a=6378137 +b=6378137 +lat_ts=0.0 +lon_0=0.0 +x_0=0.0 +y_0=0 +k=1.0 +units=m +nadgrids=@null +wktext +no_defs", "label": "WGS 84 / Pseudo-Mercator"},
    {"code": "EPSG:4326", "proj": "+proj=longlat +datum=WGS84 +no_defs", "label": "WGS 84"},
    {"code": "EPSG:2056", "proj": "+proj=somerc +lat_0=46.95240555555556 +lon_0=7.439583333333333 +k_0=1 +x_0=2600000 +y_0=1200000 +ellps=bessel +towgs84=674.374,15.056,405.346,0,0,0,0 +units=m +no_defs", "label": "CH1903+ / LV95"},
    {"code": "EPSG:21781", "proj": "+proj=somerc +lat_0=46.95240555555556 +lon_0=7.439583333333333 +k_0=1 +x_0=600000 +y_0=200000 +ellps=bessel +towgs84=674.374,15.056,405.346,0,0,0,0 +units=m +no_defs", "label": "CH1903 / LV03"},
    {"code": "EPSG:32632", "proj": "+proj=utm +zone=32 +datum=WGS84 +units=m +no_defs", "label": "WGS 84 / UTM zone 32N"}
  ],
  "plugins": {
    "common": [
      {
        "name": "Map",
        "cfg": {
          "mapOptions": {
            "zoomDuration": 250,
            "enableRotation": true,
            "panStepSize": 0.25
          },
          "toolsOptions": {
            "MeasurementSupport": {
              "geodesic": true
            }
          }
        }
      },
      {
        "name": "API"
      },
      {
        "name": "HomeButton",
        "cfg": {
          "position": 4
        }
      },
      {
        "name": "LocateButton",
        "cfg": {
          "position": 3
        }
      },
      {
        "name": "ZoomIn",
        "cfg": {
          "position": 2
        }
      },
      {
        "name": "ZoomOut",
        "cfg": {
          "position": 1
        }
      },
      {
        "name": "BackgroundSwitcher",
        "cfg": {
          "position": 0
        }
      },
      {
        "name": "TopBar",
        "cfg": {
          "menuItems": [
            {"key": "ThemeSwitcher", "icon": "themes"},
            {"key": "LayerTree", "icon": "layers"},
            {"key": "LayerCatalog", "icon": "catalog"},
            {"key": "Share", "icon": "share"},
            {"key": "Bookmark", "icon": "bookmark"},
            {"key": "Tools", "icon": "tools", "subitems": [
              {"key": "Identify", "icon": "identify_region", "mode": "Region"},
              {"key": "Measure", "icon": "measure"},
              {"key": "Redlining", "icon": "editing"},
              {"key": "GeometryDigitizer", "icon": "digitizing"},
              {"key": "AttributeTable", "icon": "editing"},
              {"key": "FeatureSearch", "icon": "search"}
            ]},
            {"key": "Print", "icon": "print"},
            {"key": "MapExport", "icon": "rasterexport"},
            {"key": "Help", "icon": "info"},
            {"key": "ExternalLink", "icon": "link", "url": "https://github.com/qgis/qwc2-demo-app"}
          ],
          "toolbarItems": [
            {"key": "Measure", "mode": "LineString", "icon": "measure_line"},
            {"key": "Measure", "mode": "Polygon", "icon": "measure_polygon"},
            {"key": "Print", "icon": "print"},
            {"key": "Identify", "icon": "identify_region", "mode": "Region"}
          ],
          "searchOptions": {
            "minScaleDenom": 1000,
            "showProviderSelection": true,
            "providerSelectionAllowAll": true,
            "zoomToLayers": false,
            "showProvidersInPlaceholder": false
          },
          "appMenuClearsTask": true,
          "appMenuFilterField": true,
          "appMenuVisibleOnStartup": false,
          "logoUrl": "/"
        }
      },
      {
        "name": "BottomBar",
        "cfg": {
          "displayCoordinates": true,
          "displayScales": true,
          "viewertitleUrl": "",
          "termsUrl": ""
        }
      },
      {
        "name": "Identify",
        "cfg": {
          "params": {
            "FI_POINT_TOLERANCE": 16,
            "FI_LINE_TOLERANCE": 8,
            "FI_POLYGON_TOLERANCE": 4,
            "feature_count": 20,
            "region_feature_count": 100
          },
          "enableExport": true,
          "longAttributesDisplay": "ellipsis",
          "displayResultTree": false,
          "featureInfoReturnsLayerName": true,
          "initialWidth": 480,
          "initialHeight": 550
        }
      },
      {
        "name": "ThemeSwitcher",
        "cfg": {
          "width": "50%"
        }
      },
      {
        "name": "LayerTree",
        "cfg": {
          "width": "25em",
          "allowMapTips": true,
          "showLegendIcons": true,
          "showRootEntry": true,
          "showQueryableIcon": true,
          "allowCompare": true,
          "allowImport": true,
          "groupTogglesSublayers": false,
          "grayUnchecked": false,
          "flattenGroups": false,
          "mapTipsEnabled": false,
          "layerInfoWindowSize": {"width": 480, "height": 400},
          "bboxDependentLegend": false
        }
      },
      {
        "name": "Measure",
        "cfg": {
          "showMeasureModeSwitcher": true
        }
      },
      {
        "name": "Print",
        "cfg": {
          "inlinePrintOutput": false,
          "printExternalLayers": true,
          "gridInitiallyEnabled": false
        }
      },
      {
        "name": "Redlining"
      },
      {
        "name": "Editing"
      },
      {
        "name": "MapCopyright"
      },
      {
        "name": "MapInfoTooltip"
      },
      {
        "name": "Share",
        "cfg": {
          "showSocials": true,
          "showLink": true,
          "showQRCode": true
        }
      },
      {
        "name": "MapTip"
      },
      {
        "name": "StartupMarker",
        "cfg": {
          "removeMode": "onclickonmarker"
        }
      },
      {
        "name": "OverviewMap",
        "cfg": {
          "position": 5,
          "visibility": false
        }
      },
      {
        "name": "ScratchDrawing"
      },
      {
        "name": "Settings"
      },
      {
        "name": "MapExport"
      },
      {
        "name": "MapCompare"
      },
      {
        "name": "HeightProfile",
        "cfg": {
          "heigthProfilePrecision": 0,
          "height": 200
        }
      },
      {
        "name": "Bookmark"
      },
      {
        "name": "LayerCatalog",
        "cfg": {
          "catalogUrl": ""
        }
      },
      {
        "name": "AttributeTable"
      },
      {
        "name": "GeometryDigitizer"
      },
      {
        "name": "FeatureForm"
      },
      {
        "name": "FeatureSearch"
      },
      {
        "name": "MapFilter"
      },
      {
        "name": "MapLegend"
      },
      {
        "name": "Portal"
      },
      {
        "name": "NewsPopup"
      },
      {
        "name": "ObjectList"
      },
      {
        "name": "TimeManager"
      },
      {
        "name": "Routing"
      },
      {
        "name": "Authentication"
      },
      {
        "name": "CookiePopup"
      },
      {
        "name": "TaskButton",
        "cfg": {
          "position": 6,
          "task": "LayerTree",
          "icon": "list-alt"
        }
      }
    ],
    "mobile": [
      {
        "name": "Map",
        "cfg": {
          "mapOptions": {
            "zoomDuration": 250,
            "enableRotation": true
          },
          "toolsOptions": {
            "MeasurementSupport": {
              "geodesic": true
            }
          }
        }
      },
      {
