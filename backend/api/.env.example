# Environment variables for Dufour API

# Database
POSTGIS_HOST=postgis
POSTGIS_PORT=5432
POSTGIS_DB=gisdb
POSTGIS_USER=gisuser
POSTGIS_PASSWORD=gispassword

# QGIS Server
QGIS_SERVER_URL=http://qgis-server:8080

# Paths
PROJECTS_DIR=/data/projects
QWC_CONFIG_DIR=/qwc-config

# API
API_TITLE=Dufour Middleware API
API_VERSION=1.0.0
